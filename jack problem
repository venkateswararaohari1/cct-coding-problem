import java.util.Scanner;

public class Main {

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        String startDay = sc.next().toLowerCase();
        int n = sc.nextInt();

        String[] days = {
            "sun", "mon", "tue", "wed",
            "thu", "fri", "sat"
        };

        int startIndex = 0;

        // Find the index of the starting day
        for (int i = 0; i < 7; i++) {
            if (days[i].equals(startDay)) {
                startIndex = i;
                break;
            }
        }

        // Day number on which the first Sunday occurs
        int firstSunday;

        if (startIndex == 0) {
            firstSunday = 1;
        } else {
            firstSunday = 8 - startIndex;
        }

        int count = 0;

        if (firstSunday <= n) {
            count = 1 + (n - firstSunday) / 7;
        }

        System.out.println(count);

        sc.close();
    }
}